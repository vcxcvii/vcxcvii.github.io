---
layout: none
permalink: /api/site.json
---
{% assign mcp_pages = site.pages | where: "mcp", true %}
{
  "generated": "{{ site.time | date_to_xmlschema }}",
  "posts": [
    {% for post in site.posts %}
    {
      "type": "post",
      "title": {{ post.title | jsonify }},
      "slug": {{ post.slug | jsonify }},
      "url": {{ post.url | absolute_url | jsonify }},
      "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
      "tags": {{ post.tags | jsonify }},
      "excerpt": {{ post.excerpt | strip_html | strip | jsonify }},
      "content": {{ post.content | strip_html | strip | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "pages": [
    {% for page in mcp_pages %}
    {
      "type": "page",
      "title": {{ page.title | jsonify }},
      "slug": {{ page.url | remove: "/" | jsonify }},
      "url": {{ page.url | absolute_url | jsonify }},
      "intro": {{ page.intro | default: "" | jsonify }},
      "content": {{ page.content | strip_html | strip | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
