---
layout: none
permalink: /api/latest.json
---
{
  "notes": [
    {% for post in site.posts limit: 5 %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | absolute_url | jsonify }},
      "date": {{ post.date | date: "%Y-%m-%d" | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
